@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">Sistema de Control Escolar</h1>
    <p class="lead">Panel principal para administración, captura y consulta de información escolar.</p>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h3 class="card-title">Alumnos</h3>
                <p class="card-text">Registrar y consultar alumnos del sistema.</p>
                <a asp-controller="Alumnos" asp-action="Index" class="btn btn-primary">Ir a Alumnos</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h3 class="card-title">Profesores</h3>
                <p class="card-text">Registrar y consultar profesores.</p>
                <a asp-controller="Profesores" asp-action="Index" class="btn btn-primary">Ir a Profesores</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h3 class="card-title">Materias</h3>
                <p class="card-text">Administrar materias disponibles.</p>
                <a asp-controller="Materias" asp-action="Index" class="btn btn-primary">Ir a Materias</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h3 class="card-title">Grupos</h3>
                <p class="card-text">Crear y consultar grupos escolares.</p>
                <a asp-controller="Grupos" asp-action="Index" class="btn btn-primary">Ir a Grupos</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h3 class="card-title">Asignaciones</h3>
                <p class="card-text">Asignar profesores y materias a grupos.</p>
                <a asp-controller="AsignacionesMateria" asp-action="Index" class="btn btn-primary">Ir a Asignaciones</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body text-center">
                <h3 class="card-title">Calificaciones</h3>
                <p class="card-text">Capturar y consultar calificaciones de alumnos.</p>
                <a asp-controller="Calificaciones" asp-action="Index" class="btn btn-primary">Ir a Calificaciones</a>
            </div>
        </div>
    </div>

    <div class="col-md-12">
        <div class="card shadow-sm border-success">
            <div class="card-body text-center">
                <h3 class="card-title">Consulta de Alumno</h3>
                <p class="card-text">Buscar calificaciones por número de boleta.</p>
                <a asp-controller="Calificaciones" asp-action="BuscarAlumno" class="btn btn-success">Consultar
                    Alumno</a>
                </div>
            </div>
        </div>
    </div>