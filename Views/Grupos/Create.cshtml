@model ControlEscolarApp.Models.Grupo

@{
    ViewData["Title"] = "Crear Grupo";
}

<h1>Crear Grupo</h1>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Nombre" class="form-label"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Semestre" class="form-label"></label>
        <input asp-for="Semestre" class="form-control" />
        <span asp-validation-for="Semestre" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}