@model ControlEscolarApp.Models.Grupo

@{
    ViewData["Title"] = "Eliminar Grupo";
}

<h1>Eliminar Grupo</h1>

<h4>¿Seguro que deseas eliminar este grupo?</h4>
<hr />

<dl class="row">
    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.Nombre</dd>

    <dt class="col-sm-3">Semestre</dt>
    <dd class="col-sm-9">@Model.Semestre</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>