@model ControlEscolarApp.Models.Calificacion

@{
    ViewData["Title"] = "Eliminar Calificación";
}

<h1>Eliminar Calificación</h1>

<h4>¿Seguro que deseas eliminar esta calificación?</h4>
<hr />

<dl class="row">
    <dt class="col-sm-3">Boleta</dt>
    <dd class="col-sm-9">@Model.Alumno?.NumeroBoleta</dd>

    <dt class="col-sm-3">Alumno</dt>
    <dd class="col-sm-9">@Model.Alumno?.Nombre @Model.Alumno?.ApellidoPaterno</dd>

    <dt class="col-sm-3">Materia</dt>
    <dd class="col-sm-9">@Model.Materia?.Nombre</dd>

    <dt class="col-sm-3">Grupo</dt>
    <dd class="col-sm-9">@Model.Grupo?.Nombre</dd>

    <dt class="col-sm-3">Profesor</dt>
    <dd class="col-sm-9">@Model.Profesor?.Nombre @Model.Profesor?.ApellidoPaterno</dd>

    <dt class="col-sm-3">Final</dt>
    <dd class="col-sm-9">@Model.Final</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>